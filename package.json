{
  "name": "js-api-hunter",
  "displayName": "JS API Hunter",
  "description": "从 JS 文件中自动发现隐藏 API 接口，拼装完整请求，批量越权/Fuzz 测试。将 JS 接口挖洞的七步手工作坊升级为一键自动化流水线。",
  "version": "0.3.1",
  "publisher": "ookini-kawaii",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ookini-kawaii/js-api-hunter"
  },
  "bugs": {
    "url": "https://github.com/ookini-kawaii/js-api-hunter/issues"
  },
  "homepage": "https://github.com/ookini-kawaii/js-api-hunter#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "security",
    "api",
    "endpoint",
    "javascript",
    "pentest",
    "bug-bounty",
    "recon",
    "fuzzer",
    "vulnerability",
    "idor",
    "sqli",
    "ssrf",
    "auth-bypass",
    "mcp"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:js-api-hunter-endpoints"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jsApiHunter.scan",
        "title": "JS API Hunter: 新建扫描",
        "icon": "$(search)"
      },
      {
        "command": "jsApiHunter.refresh",
        "title": "JS API Hunter: 刷新结果",
        "icon": "$(refresh)"
      },
      {
        "command": "jsApiHunter.clear",
        "title": "JS API Hunter: 清空结果",
        "icon": "$(clear-all)"
      },
      {
        "command": "jsApiHunter.viewEndpointDetail",
        "title": "查看端点详情"
      },
      {
        "command": "jsApiHunter.copyEndpoint",
        "title": "复制完整请求 URL"
      },
      {
        "command": "jsApiHunter.copyAsCurl",
        "title": "复制为 cURL"
      },
      {
        "command": "jsApiHunter.copyAsPython",
        "title": "复制为 Python requests"
      },
      {
        "command": "jsApiHunter.exportResults",
        "title": "JS API Hunter: 导出结果",
        "icon": "$(save)"
      },
      {
        "command": "jsApiHunter.fuzzEndpoint",
        "title": "JS API Hunter: Fuzz 测试端点",
        "icon": "$(debug-start)"
      },
      {
        "command": "jsApiHunter.horizontalFuzz",
        "title": "JS API Hunter: 横向 Fuzz（多子域名）",
        "icon": "$(globe)"
      },
      {
        "command": "jsApiHunter.analyzeSignatures",
        "title": "JS API Hunter: 分析签名/加密逻辑",
        "icon": "$(key)"
      },
      {
        "command": "jsApiHunter.enumerateSubdomains",
        "title": "JS API Hunter: 子域名枚举",
        "icon": "$(globe)"
      },
      {
        "command": "jsApiHunter.showSecrets",
        "title": "JS API Hunter: 查看敏感信息",
        "icon": "$(shield)"
      },
      {
        "command": "jsApiHunter.verifyEndpoints",
        "title": "JS API Hunter: 重放验证端点",
        "icon": "$(check)"
      },
      {
        "command": "jsApiHunter.setupMcp",
        "title": "JS API Hunter: MCP 集成配置",
        "icon": "$(plug)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "jsApiHunter.scan",
          "when": "view == js-api-hunter-endpoints",
          "group": "navigation@1"
        },
        {
          "command": "jsApiHunter.enumerateSubdomains",
          "when": "view == js-api-hunter-endpoints",
          "group": "navigation@2"
        },
        {
          "command": "jsApiHunter.exportResults",
          "when": "view == js-api-hunter-endpoints",
          "group": "navigation@3"
        },
        {
          "command": "jsApiHunter.refresh",
          "when": "view == js-api-hunter-endpoints",
          "group": "navigation@4"
        },
        {
          "command": "jsApiHunter.clear",
          "when": "view == js-api-hunter-endpoints",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "jsApiHunter.fuzzEndpoint",
          "when": "view == js-api-hunter-endpoints && viewItem == endpoint",
          "group": "inline@1"
        },
        {
          "command": "jsApiHunter.viewEndpointDetail",
          "when": "view == js-api-hunter-endpoints && viewItem == endpoint",
          "group": "context@1"
        },
        {
          "command": "jsApiHunter.copyEndpoint",
          "when": "view == js-api-hunter-endpoints && viewItem == endpoint",
          "group": "context@2"
        },
        {
          "command": "jsApiHunter.copyAsCurl",
          "when": "view == js-api-hunter-endpoints && viewItem == endpoint",
          "group": "context@3"
        },
        {
          "command": "jsApiHunter.copyAsPython",
          "when": "view == js-api-hunter-endpoints && viewItem == endpoint",
          "group": "context@4"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "js-api-hunter-sidebar",
          "title": "JS API Hunter",
          "icon": "$(search)"
        }
      ]
    },
    "views": {
      "js-api-hunter-sidebar": [
        {
          "id": "js-api-hunter-endpoints",
          "name": "发现的端点"
        }
      ]
    },
    "configuration": {
      "title": "JS API Hunter",
      "properties": {
        "jsApiHunter.concurrentRequests": {
          "type": "number",
          "default": 10,
          "description": "并发请求数（用于 Fuzz/子域名枚举阶段）"
        },
        "jsApiHunter.timeout": {
          "type": "number",
          "default": 30000,
          "description": "请求超时时间（毫秒）"
        },
        "jsApiHunter.userAgent": {
          "type": "string",
          "default": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
          "description": "自定义 User-Agent"
        },
        "jsApiHunter.userToken": {
          "type": "string",
          "default": "",
          "description": "默认测试 Token（Bearer xxx），Fuzz 时会同时测带 Token 和裸奔两个版本"
        },
        "jsApiHunter.verifyEndpoints": {
          "type": "boolean",
          "default": true,
          "description": "扫描完成后是否自动对端点做重放验证"
        },
        "jsApiHunter.verifyTimeout": {
          "type": "number",
          "default": 5000,
          "description": "单个端点重放验证超时时间（毫秒）"
        },
        "jsApiHunter.verifyConcurrency": {
          "type": "number",
          "default": 5,
          "description": "重放验证并发数"
        },
        "jsApiHunter.pathVariants": {
          "type": "boolean",
          "default": true,
          "description": "横向 Fuzz 时是否启用路径变异（去掉 api/版本号、加 admin 前缀等）"
        },
        "jsApiHunter.subdomainPrefixes": {
          "type": "array",
          "default": [
            "test",
            "dev",
            "staging",
            "uat",
            "qa",
            "old",
            "legacy",
            "internal",
            "admin",
            "manage",
            "manager",
            "api",
            "app",
            "mobile",
            "wap",
            "beta",
            "alpha",
            "demo",
            "sandbox",
            "preprod",
            "pre",
            "stage",
            "cms",
            "portal",
            "console",
            "dashboard",
            "user-svc",
            "order-svc",
            "pay-svc",
            "gateway",
            "gw",
            "test-api",
            "dev-api",
            "staging-api"
          ],
          "description": "子域名枚举默认前缀列表"
        },
        "jsApiHunter.testAuthBypass": {
          "type": "boolean",
          "default": true,
          "description": "Fuzz 时是否测试鉴权绕过"
        },
        "jsApiHunter.testIdor": {
          "type": "boolean",
          "default": true,
          "description": "Fuzz 时是否测试 URL 路径 IDOR"
        },
        "jsApiHunter.testIdorBody": {
          "type": "boolean",
          "default": true,
          "description": "Fuzz 时是否测试 Body/Query IDOR"
        },
        "jsApiHunter.testParamInject": {
          "type": "boolean",
          "default": true,
          "description": "Fuzz 时是否测试参数注入"
        },
        "jsApiHunter.testSqlInject": {
          "type": "boolean",
          "default": true,
          "description": "Fuzz 时是否测试 SQL 注入"
        },
        "jsApiHunter.testNoSqlInject": {
          "type": "boolean",
          "default": true,
          "description": "Fuzz 时是否测试 NoSQL 注入"
        },
        "jsApiHunter.testSsrf": {
          "type": "boolean",
          "default": true,
          "description": "Fuzz 时是否测试 SSRF"
        },
        "jsApiHunter.testMassAssignment": {
          "type": "boolean",
          "default": true,
          "description": "Fuzz 时是否测试 Mass Assignment"
        },
        "jsApiHunter.testBusinessLogic": {
          "type": "boolean",
          "default": true,
          "description": "Fuzz 时是否测试业务逻辑"
        },
        "jsApiHunter.testInterfaceAbuse": {
          "type": "boolean",
          "default": true,
          "description": "Fuzz 时是否测试接口滥用（短信轰炸/验证码爆破/刷券）"
        },
        "jsApiHunter.testRaceCondition": {
          "type": "boolean",
          "default": true,
          "description": "Fuzz 时是否测试并发竞态"
        },
        "jsApiHunter.testSignBypass": {
          "type": "boolean",
          "default": true,
          "description": "Fuzz 时是否测试签名绕过（删除签名字段/头）"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run bundle",
    "compile": "tsc -p ./",
    "bundle": "node esbuild.js",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "acorn": "^8.11.0",
    "acorn-walk": "^8.3.0",
    "puppeteer-core": "^22.0.0"
  }
}
